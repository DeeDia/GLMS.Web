@model GLMS.Web.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<h2>Contract Details</h2>

<dl class="row">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client?.Name</dd>

    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        <span class="badge
            @(Model.Status == GLMS.Web.Models.ContractStatus.Active
                              ? "bg-success"
                              : Model.Status == GLMS.Web.Models.ContractStatus.Expired
                                  ? "bg-danger"
                                  : "bg-secondary")">
            @Model.Status
        </span>
    </dd>

    <dt class="col-sm-3">Service Level</dt>
    <dd class="col-sm-9">@Model.ServiceLevel</dd>

    <dt class="col-sm-3">Signed Agreement</dt>
    <dd class="col-sm-9">
        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
        {
            <!-- Download button -->
            <a asp-action="DownloadAgreement"
               asp-route-id="@Model.Id"
               class="btn btn-sm btn-outline-primary">
                Download PDF
            </a>
        }
        else
        {
            <span class="text-muted">No file uploaded</span>
        }
    </dd>
</dl>

<a asp-action="Index" class="btn btn-secondary">Back to List</a>